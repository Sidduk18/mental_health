{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["teen", "adult"] },
        "anonymous": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "streak": { "type": "integer" },
        "lastActive": { "type": "string", "format": "date-time" },
        "preferences": { "type": "object" }
      },
      "required": ["uid", "email", "role"]
    },
    "MoodLog": {
      "title": "MoodLog",
      "description": "Daily mood check-in",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "mood": { "type": "integer" },
        "note": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "mood", "timestamp"]
    },
    "JournalEntry": {
      "title": "JournalEntry",
      "description": "Personal journal entry",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "voice"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "content", "timestamp"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Therapist booking",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "therapistId": { "type": "string" },
        "dateTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["scheduled", "completed", "cancelled"] },
        "duration": { "type": "integer" },
        "meetLink": { "type": "string" },
        "totalCost": { "type": "number" }
      },
      "required": ["userId", "therapistId", "dateTime", "status", "duration", "meetLink", "totalCost"]
    },
    "Goal": {
      "title": "Goal",
      "description": "User set goal",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "completed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "completed"]
    },
    "Assessment": {
      "title": "Assessment",
      "description": "Clinical assessment (PHQ-9, GAD-7)",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["PHQ-9", "GAD-7"] },
        "score": { "type": "integer" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "score", "timestamp"]
    },
    "PeerPost": {
      "title": "PeerPost",
      "description": "Moderated peer support post",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "content": { "type": "string" },
        "anonymous": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" },
        "likes": { "type": "array", "items": { "type": "string" } },
        "comments": { "type": "array" }
      },
      "required": ["userId", "content", "timestamp"]
    },
    "Message": {
      "title": "Message",
      "description": "In-app message",
      "type": "object",
      "properties": {
        "appointmentId": { "type": "string" },
        "userId": { "type": "string" },
        "senderId": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["appointmentId", "userId", "senderId", "content", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/moods/{moodId}": {
      "schema": "MoodLog",
      "description": "Mood tracking logs"
    },
    "/journals/{journalId}": {
      "schema": "JournalEntry",
      "description": "Journal entries"
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Therapy appointments"
    },
    "/goals/{goalId}": {
      "schema": "Goal",
      "description": "User goals"
    },
    "/assessments/{assessmentId}": {
      "schema": "Assessment",
      "description": "Clinical assessments"
    },
    "/peer_posts/{postId}": {
      "schema": "PeerPost",
      "description": "Peer support community posts"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Direct messages"
    }
  }
}
